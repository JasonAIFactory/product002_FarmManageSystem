# Database — same Supabase PG as Phase 1
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-region.supabase.com:5432/postgres

# Auth
JWT_SECRET=change-me-in-production

# Kakao OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/v1/auth/kakao/callback

# AI / STT
OPENAI_API_KEY=         # Whisper (voice → text)
ANTHROPIC_API_KEY=      # Claude (text → structured farm log)

# Korean public APIs (data.go.kr)
KMA_API_KEY=            # 기상청 단기예보 — get from https://www.data.go.kr/data/15084084/openapi.do

# Redis — optional, enables async voice processing via Celery
# Without Redis, voice processing runs synchronously (fine for single-farmer MVP)
REDIS_URL=              # redis://localhost:6379/0

# Supabase Storage (same as Phase 1)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# App
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
