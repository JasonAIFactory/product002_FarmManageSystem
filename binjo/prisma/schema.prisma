generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Farm {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String   @db.VarChar(100)
  name_en          String?  @db.VarChar(100)
  tagline          String?  @db.Text
  story            String?  @db.Text
  phone            String?  @db.VarChar(20)
  kakao_chat_url   String?  @db.VarChar(500)
  naver_store_url  String?  @db.VarChar(500)
  youtube_url      String?  @db.VarChar(500)
  address          String?  @db.Text
  address_short    String?  @db.VarChar(100)
  latitude         Decimal? @db.Decimal(10, 7)
  longitude        Decimal? @db.Decimal(10, 7)
  hero_image_url   String?  @db.VarChar(500)
  farmer_image_url String?  @db.VarChar(500)
  stats            Json?
  sections_config  Json?
  created_at       DateTime @default(now()) @db.Timestamptz()
  updated_at       DateTime @updatedAt @db.Timestamptz()

  products          Product[]
  seasonal_calendar SeasonalCalendar[]
  gallery_photos    GalleryPhoto[]
  reviews           Review[]
  order_inquiries   OrderInquiry[]

  @@map("farm")
}

model Product {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farm_id             String   @db.Uuid
  name                String   @db.VarChar(100)
  name_en             String?  @db.VarChar(100)
  description         String?  @db.Text
  short_description   String?  @db.VarChar(200)
  harvest_start_month Int?
  harvest_end_month   Int?
  is_available        Boolean  @default(false)
  price_options       Json?
  image_url           String?  @db.VarChar(500)
  sort_order          Int      @default(0)
  created_at          DateTime @default(now()) @db.Timestamptz()
  updated_at          DateTime @updatedAt @db.Timestamptz()

  farm            Farm           @relation(fields: [farm_id], references: [id])
  order_inquiries OrderInquiry[]

  @@map("product")
}

model SeasonalCalendar {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farm_id            String   @db.Uuid
  month              Int
  activities         String[]
  available_products String[]
  highlight          String?  @db.Text
  created_at         DateTime @default(now()) @db.Timestamptz()

  farm Farm @relation(fields: [farm_id], references: [id])

  @@unique([farm_id, month])
  @@map("seasonal_calendar")
}

model GalleryPhoto {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farm_id    String    @db.Uuid
  image_url  String    @db.VarChar(500)
  caption    String?   @db.VarChar(200)
  taken_at   DateTime? @db.Date
  sort_order Int       @default(0)
  created_at DateTime  @default(now()) @db.Timestamptz()

  farm Farm @relation(fields: [farm_id], references: [id])

  @@map("gallery_photo")
}

model Review {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farm_id           String   @db.Uuid
  customer_name     String?  @db.VarChar(50)
  customer_location String?  @db.VarChar(50)
  content           String   @db.Text
  rating            Int      @default(5)
  is_visible        Boolean  @default(true)
  sort_order        Int      @default(0)
  created_at        DateTime @default(now()) @db.Timestamptz()

  farm Farm @relation(fields: [farm_id], references: [id])

  @@map("review")
}

model OrderInquiry {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farm_id    String   @db.Uuid
  channel    String   @db.VarChar(20)
  product_id String?  @db.Uuid
  referrer   String?  @db.VarChar(500)
  created_at DateTime @default(now()) @db.Timestamptz()

  farm    Farm     @relation(fields: [farm_id], references: [id])
  product Product? @relation(fields: [product_id], references: [id])

  @@map("order_inquiry")
}
